---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import TableOfContents from "@components/blog/TableOfContents.astro";
import SocialShare from "@components/blog/SocialShare.astro";
import { getPostBySlug, getPosts } from "@lib/content";
import { marked } from "marked";
import { Image } from "astro:assets";

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect("/404");
}

const contentHtml = marked.parse(post.content);

// Get Related Posts
const allPosts = await getPosts();
const relatedPosts = allPosts
  .filter(p => p.slug !== slug && p.category === post.category)
  .slice(0, 3);

const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<Layout 
  title={post.title} 
  description={post.description} 
  image={post.image}
  ogType="article"
>
  <Container>
    <article class="mx-auto max-w-4xl mt-20 animate-fade-in">
        <header class="text-center mb-12 max-w-2xl mx-auto">
            <span class="text-brand-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
                {post.category}
            </span>
            <h1 class="text-4xl md:text-5xl font-bold mb-8 leading-tight dark:text-white">
                {post.title}
            </h1>
            <div class="flex items-center justify-center gap-4 text-slate-500 dark:text-slate-400">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-brand-primary flex items-center justify-center text-xs font-bold text-white uppercase transition-colors">
                        {post.author[0]}
                    </div>
                    <span class="text-slate-900 dark:text-slate-300 font-medium">{post.author}</span>
                </div>
                <span>•</span>
                <time datetime={post.pubDate.toISOString()}>
                    {post.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
            </div>
        </header>

        {post.image && (
            <div class="w-full aspect-video rounded-3xl overflow-hidden mb-12 glass shadow-2xl bg-slate-900">
                {(() => {
                    let imageSrc = post.image;
                    
                    // Jika path relatif (seperti "image.webp" atau "./image.webp"), 
                    // kita asumsikan ini adalah file di src/content tapi karena kita tidak pakai image(),
                    // kita butuh fallback atau cara lain. Untuk sekarang, kita coba tampilkan apa adanya.
                    
                    // Skenario 1: Path lama (dimulai dengan /)
                    if (typeof imageSrc === 'string' && (imageSrc.startsWith('/') || imageSrc.startsWith('http'))) {
                        return <img src={imageSrc} class="w-full h-full object-cover" alt={post.title} loading="eager" />;
                    }
                    
                    // Skenario 2: Path baru (relatif ke folder berita di src/content)
                    // Karena kita simpan di src, tapi kita ingin tampil di public, 
                    // Keystatic punya setting untuk memindahkan ini.
                    
                    return <img src={imageSrc} class="w-full h-full object-cover" alt={post.title} loading="eager" />;
                })()}
            </div>
        )}

        <div class="grid lg:grid-cols-[1fr_250px] gap-12">
          <!-- Main Content -->
          <div>
            <SocialShare title={post.title} url={postUrl} />
            
            <div class="prose dark:prose-invert prose-indigo prose-lg max-w-none prose-h2:text-3xl prose-h2:font-bold prose-p:text-slate-600 dark:prose-p:text-slate-300 prose-p:leading-loose prose-a:text-brand-primary">
                <Fragment set:html={contentHtml} />
            </div>

            <SocialShare title={post.title} url={postUrl} />

            <!-- Related Posts Section -->
            {relatedPosts.length > 0 && (
              <div class="mt-20 pt-12 border-t border-slate-200 dark:border-slate-800">
                <h3 class="text-2xl font-bold mb-8">Artikel Terkait</h3>
                <div class="grid md:grid-cols-2 gap-8">
                  {relatedPosts.map(p => (
                    <a href={`/blog/${p.slug}`} class="group">
                      <div class="aspect-video rounded-2xl overflow-hidden mb-4 bg-slate-100 dark:bg-slate-900">
                        {typeof p.image === 'string' ? (
                          <img 
                            src={p.image} 
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                            alt={p.title}
                            loading="lazy"
                          />
                        ) : (
                          <Image 
                            src={p.image} 
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                            alt={p.title}
                            loading="lazy"
                            width={400}
                            height={225}
                          />
                        )}
                      </div>
                      <h4 class="font-bold text-lg group-hover:text-violet-500 transition-colors">{p.title}</h4>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents />
              
              <!-- Sidebar Ad Slot -->
              <div class="mt-8 p-4 bg-slate-100 dark:bg-slate-900 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700 text-center">
                <span class="text-[10px] text-slate-400 uppercase tracking-widest block mb-2">Advertisement</span>
                <slot name="post-sidebar-ad" />
              </div>
            </div>
          </aside>
        </div>

        <div class="mt-20 pt-12 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center mb-20">
            <a href="/blog" class="group flex items-center gap-2 text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                <span class="transform group-hover:-translate-x-1 transition-transform">←</span>
                Semua Artikel
            </a>
        </div>
    </article>
  </Container>
</Layout>

<style is:global>
    .prose h2, .prose h3 {
        margin-top: 2.5rem;
        margin-bottom: 1.5rem;
        scroll-margin-top: 100px;
    }
    .prose p {
        margin-bottom: 1.5rem;
    }
</style>

