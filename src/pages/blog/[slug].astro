---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import TableOfContents from "@components/blog/TableOfContents.astro";
import SocialShare from "@components/blog/SocialShare.astro";
import { getPostBySlug, getPosts } from "@lib/content";
import { marked } from "marked";
import { Image } from "astro:assets";

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect("/404");
}

const contentHtml = marked.parse(post.content);

// Get Related Posts
const allPosts = await getPosts();
const relatedPosts = allPosts
  .filter(p => p.slug !== slug && p.category === post.category)
  .slice(0, 3);

const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<Layout 
  title={post.title} 
  description={post.description} 
  image={post.image}
  ogType="article"
>
  <Container>
    <article class="mx-auto max-w-4xl mt-20 animate-fade-in">
        <header class="text-center mb-12 max-w-2xl mx-auto">
            <span class="text-brand-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
                {post.category}
            </span>
            <h1 class="text-3xl md:text-4xl font-bold mb-8 leading-tight dark:text-white">
                {post.title}
            </h1>
            <div class="flex items-center justify-center gap-4 text-slate-500 dark:text-slate-400">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg border-2 border-brutal-border bg-brutal-warning flex items-center justify-center text-lg font-black !text-slate-900 uppercase shadow-[2px_2px_0_#0f172a] -rotate-3 hover:rotate-3 transition-transform cursor-default">
                        {post.author[0]}
                    </div>
                    <span class="text-slate-900 dark:text-white font-extrabold text-lg">{post.author}</span>
                </div>
                <span>•</span>
                <time datetime={post.pubDate.toISOString()}>
                    {post.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
            </div>
        </header>

        {post.image && (
            <div class="w-full aspect-video rounded-3xl overflow-hidden mb-12 glass shadow-2xl bg-slate-900">
                {(() => {
                    let imageSrc = post.image;
                    
                    // Jika path relatif (seperti "image.webp" atau "./image.webp"), 
                    // kita asumsikan ini adalah file di src/content tapi karena kita tidak pakai image(),
                    // kita butuh fallback atau cara lain. Untuk sekarang, kita coba tampilkan apa adanya.
                    
                    // Skenario 1: Path lama (dimulai dengan /)
                    if (typeof imageSrc === 'string' && (imageSrc.startsWith('/') || imageSrc.startsWith('http'))) {
                        return <img src={imageSrc} class="w-full h-full object-cover" alt={post.title} loading="eager" />;
                    }
                    
                    // Skenario 2: Path baru (relatif ke folder berita di src/content)
                    // Karena kita simpan di src, tapi kita ingin tampil di public, 
                    // Keystatic punya setting untuk memindahkan ini.
                    
                    return <img src={imageSrc} class="w-full h-full object-cover" alt={post.title} loading="eager" />;
                })()}
            </div>
        )}

        <div class="grid lg:grid-cols-[1fr_250px] gap-12">
          <!-- Main Content -->
          <div>
            <SocialShare title={post.title} url={postUrl} />
            
            <div class="prose dark:prose-invert prose-indigo prose-lg max-w-none prose-h2:text-2xl prose-h2:font-bold prose-p:text-slate-600 dark:prose-p:text-slate-300 prose-p:leading-loose prose-a:text-brand-primary">
                <Fragment set:html={contentHtml} />
            </div>

            <SocialShare title={post.title} url={postUrl} />

            <!-- Related Posts Section -->
            {relatedPosts.length > 0 && (
              <div class="mt-24 pt-12 border-t-4 border-brutal-border">
                <h3 class="text-2xl font-extrabold mb-8 text-brutal-text">Artikel Terkait</h3>
                <div class="grid md:grid-cols-2 gap-8">
                  {relatedPosts.map((p, index) => {
                    const cardStyles = [
                      { card: '!bg-[#fae870]', icon: '!bg-[#fef08a]', tag: '!bg-white' },
                      { card: '!bg-[#c0e6ff]', icon: '!bg-[#7dd3fc]', tag: '!bg-[#bae6fd]' },
                      { card: '!bg-[#f8ddb2]', icon: '!bg-[#fdba74]', tag: '!bg-[#fcd34d]' }
                    ];
                    const style = cardStyles[index % cardStyles.length];

                    return (
                    <article class="h-full">
                        <a href={`/blog/${p.slug}`} class={`block h-full brutal-card overflow-hidden flex flex-col group ${style.card} transition-colors`}>
                            <div class="aspect-video relative p-0 border-b-3 border-brutal-border !bg-white overflow-hidden">
                                {typeof p.image === 'string' ? (
                                  <img src={p.image} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt={p.title} loading="lazy" />
                                ) : (
                                  <Image src={p.image} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt={p.title} loading="lazy" width={400} height={225} />
                                )}
                            </div>
                            <div class="p-5 flex flex-col flex-grow">
                                <div class="flex items-start gap-3 mb-2">
                                    <div class={`w-8 h-8 rounded-lg border-2 border-brutal-border flex items-center justify-center shrink-0 shadow-[2px_2px_0_#0f172a] group-hover:rotate-6 transition-transform ${style.icon}`}>
                                        <svg class="w-4 h-4 !text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                                        </svg>
                                    </div>
                                    <h4 class="text-lg font-extrabold group-hover:text-blue-700 transition-colors line-clamp-2 leading-tight !text-slate-900">{p.title}</h4>
                                </div>
                                <p class="!text-slate-800 line-clamp-2 text-xs leading-relaxed mb-6 flex-grow font-bold">{p.description}</p>
                                <div class="flex justify-between items-end mt-auto">
                                    <span class={`px-2.5 py-1 border-2 border-brutal-border rounded-full text-[9px] font-extrabold uppercase tracking-widest !text-slate-900 shadow-[2px_2px_0_#0f172a] dark:shadow-[2px_2px_0_#0f172a] ${style.tag}`}>
                                        {p.category}
                                    </span>
                                    <span class="bg-[#131b2d] text-white px-4 py-2 rounded-full text-[11px] font-extrabold border-2 border-transparent group-hover:scale-105 transition-transform flex items-center gap-1.5">
                                        BACA <span>&rarr;</span>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </article>
                  )})}
                </div>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents />
              
              <!-- Sidebar Ad Slot -->
              <div class="mt-8 p-4 bg-slate-100 dark:bg-slate-900 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700 text-center">
                <span class="text-[10px] text-slate-400 uppercase tracking-widest block mb-2">Advertisement</span>
                <slot name="post-sidebar-ad" />
              </div>
            </div>
          </aside>
        </div>

        <div class="mt-20 pt-12 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center mb-20">
            <a href="/blog" class="group flex items-center gap-2 text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                <span class="transform group-hover:-translate-x-1 transition-transform">←</span>
                Semua Artikel
            </a>
        </div>
    </article>
  </Container>
</Layout>

<style is:global>
    .prose h2, .prose h3 {
        margin-top: 2.5rem;
        margin-bottom: 1.5rem;
        scroll-margin-top: 100px;
    }
    .prose p {
        margin-bottom: 1.5rem;
    }
</style>

