        const MarketSight = () => {
          const [activeTab, setActiveTab] = useState('dashboard');
          const [savedNiches, setSavedNiches] = useState([]);
          const [sessionKeyword, setSessionKeyword] = useState(''); // GLOBAL KEYWORD STATE
          const [lang, setLang] = useState('en');

          // Translation helper
          const t = (key) => translations[lang][key] || key;
          
          useEffect(() => {
            const saved = localStorage.getItem('marketSightSaved');
            if (saved) {
              setSavedNiches(JSON.parse(saved));
            }
          }, []);

          useEffect(() => {
            localStorage.setItem('marketSightSaved', JSON.stringify(savedNiches));
          }, [savedNiches]);

          const addToSaved = (niche) => {
            if (!savedNiches.find(n => n.id === niche.id)) {
              setSavedNiches([niche, ...savedNiches]); 
            }
          };

          const removeFromSaved = (id) => {
            setSavedNiches(savedNiches.filter(n => n.id !== id));
          };

          const updateSessionKeyword = (keyword) => {
            if (keyword && keyword.trim() !== '') {
              setSessionKeyword(keyword);
            }
          };

          // Navigate & Sync
          const navigateTo = (tabName, keyword = null) => {
            if (keyword) updateSessionKeyword(keyword);
            setActiveTab(tabName);
          };

