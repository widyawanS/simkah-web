---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import { getPosts } from "@lib/content.ts";
import { getHomepage } from "@lib/keystatic";
import { getBadgeColor } from "@utils/all";
import AdSlot from "@components/ui/AdSlot.astro";
import { Image } from "astro:assets";

const latestPosts = await getPosts();
const featuredPost = latestPosts[0];
const homepageData = await getHomepage();

const heroTitle = homepageData?.heroTitle || "Build with Intelligence";
const heroSubtitle = homepageData?.heroSubtitle || "Kumpulan artikel mendalam, alat produktivitas pintar, dan generator prompt untuk masa depan kreatif Anda.";
const heroButtonText = homepageData?.heroButtonText;
const heroButtonLink = homepageData?.heroButtonLink;
---

<Layout title="simkah.web.id">
  <main class="py-12 relative">
    <!-- Hero Section (Xgrind Pro Style) -->
    <section class="mb-24 mt-10 text-center px-4 max-w-5xl mx-auto">
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 brutal-pill bg-white border-2 border-brutal-border shadow-brutal-sm">
          <span class="text-brand-primary animate-pulse">⚡</span>
          <span class="text-xs font-extrabold tracking-widest text-brutal-text">FREE PRODUCTIVITY TOOLS</span>
        </div>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 tracking-tight leading-[1.1] text-brutal-text text-center">
        {heroTitle.includes(' ') ? (
          <>
            <span class="mr-3">{heroTitle.split(' ').slice(0, -1).join(' ')}</span>
            <span class="inline-block whitespace-nowrap">
              <span class="relative inline-block px-3 mx-1">
                <span class="absolute inset-0 bg-brutal-warning transform -skew-x-12 -rotate-2 rounded-sm border-2 border-brutal-border dark:border-slate-800"></span>
                <span class="relative z-10 !text-slate-900 dark:!text-slate-900">{heroTitle.split(' ').slice(-1)}</span>
              </span>
              <svg class="inline-block w-6 h-6 md:w-8 md:h-8 ml-2 text-brutal-accent animate-sparkle align-text-top" style="filter: drop-shadow(2px 2px 0 var(--brutal-shadow-color)); transform: translateY(4px);" viewBox="0 0 24 24" fill="currentColor" stroke="var(--brutal-border-color)" stroke-width="1.5" stroke-linejoin="round">
                <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z"/>
              </svg>
            </span>
          </>
        ) : (
          <>
            {heroTitle}
            <svg class="inline-block w-6 h-6 md:w-8 md:h-8 ml-2 text-brutal-accent animate-sparkle align-text-top" style="filter: drop-shadow(2px 2px 0 var(--brutal-shadow-color)); transform: translateY(4px);" viewBox="0 0 24 24" fill="currentColor" stroke="var(--brutal-border-color)" stroke-width="1.5" stroke-linejoin="round">
              <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z"/>
            </svg>
          </>
        )}
      </h1>
      
      <p class="text-base md:text-lg text-brutal-text-muted whitespace-pre-line mb-10 font-bold max-w-3xl mx-auto">
        {heroSubtitle.replace("Gratis selamanya.", "")} <span class="text-brutal-text font-extrabold">Gratis selamanya.</span>
      </p>

      <div class="brutal-pill brutal-pill-mobile-card md:brutal-pill-desktop p-3 flex flex-col md:flex-row gap-2 bg-white max-w-3xl mx-auto mb-6">
        <div class="relative flex-1">
           <span class="absolute left-5 top-1/2 -translate-y-1/2 text-brutal-text-muted">
             <svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
             </svg>
           </span>
           <button class="search-btn-trigger w-full h-full text-left bg-brutal-bg-alt rounded-full py-3.5 pl-14 pr-6 font-bold text-brutal-text-muted text-base border-2 border-transparent hover:border-brutal-border transition-colors outline-none">
              Cari tools atau artikel...
           </button>
        </div>
        
        {heroButtonText && (
          <a 
            href={heroButtonLink || "#"} 
            class="brutal-btn bg-brutal-secondary text-white px-6 py-3.5 text-base"
          >
            {heroButtonText}
          </a>
        )}
      </div>
      
      <div class="flex items-center gap-4 text-sm font-bold text-brutal-text-muted justify-center mt-6">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-brutal-success"></div>
          <span>Tanpa login</span>
        </div>
        <span>·</span>
        <span>Akses instan</span>
      </div>
    </section>

    <!-- Bento Grid Section -->
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Featured Post -->
        {featuredPost && (
          <div class="md:col-span-2 md:row-span-2 animate-float-smooth">
            <div class="brutal-card group relative overflow-hidden h-full">
              <a href={`/blog/${featuredPost.slug}`}>
                  <div class="p-8 h-full flex flex-col justify-end relative z-10 bg-gradient-to-t from-[#1e1e24] to-transparent min-h-[300px]">
                  <span class={`brutal-badge ${getBadgeColor(featuredPost.category)} text-brutal-text mb-2 w-fit`}>{featuredPost.category}</span>
                  <h2 class="text-2xl md:text-3xl font-extrabold mb-3 text-white group-hover:text-brutal-accent transition-colors">{featuredPost.title}</h2>
                  <p class="text-slate-300 line-clamp-2 mb-5 text-sm">{featuredPost.description}</p>
                  <div class="flex items-center gap-3">
                    <div class="w-7 h-7 rounded-full bg-brutal-primary border-2 border-white/30 flex items-center justify-center text-[10px] font-extrabold text-white uppercase">
                      {featuredPost.author[0]}
                    </div>
                    <span class="text-sm font-bold text-white">{featuredPost.author}</span>
                  </div>
                </div>
                {featuredPost.image && (
                   typeof featuredPost.image === 'string' ? (
                     <img 
                      src={featuredPost.image} 
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-40" 
                      alt={featuredPost.title}
                      loading="eager"
                     />
                   ) : (
                     <Image 
                      src={featuredPost.image} 
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-40" 
                      alt={featuredPost.title}
                      width={1200}
                      height={675}
                      loading="eager"
                     />
                   )
                )}
            </a>
          </div>
        </div>
        )}

        <!-- Tools Card 1: Calculator -->
        <div class="brutal-card p-8 flex flex-col justify-between group !bg-[#fae870] hover:!-translate-y-1 transition-transform">
          <div>
            <div class="w-10 h-10 rounded-full bg-brutal-primary border-2 border-brutal-border flex items-center justify-center mb-5 group-hover:rotate-6 transition-transform shadow-brutal-sm">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 !text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
               </svg>
            </div>
            <h3 class="text-lg font-extrabold mb-2 !text-slate-900">Smart Calculators</h3>
            <p class="text-xs !text-slate-700 font-medium">Kalkulator Keluarga, Wedding, Undangan, dll.</p>
          </div>
          <a href="/tools/calculators" class="!text-slate-900 font-extrabold text-xs flex items-center gap-2 group-hover:gap-4 transition-all mt-4 uppercase tracking-wider">
            Explore <span class="text-lg">→</span>
          </a>
        </div>

        <!-- Tools Card 2: Tool AI Penghulu -->
        <div class="brutal-card p-8 flex flex-col justify-between group !bg-[#c0e6ff] hover:!-translate-y-1 transition-transform">
          <div>
            <div class="w-10 h-10 rounded-full bg-brutal-secondary border-2 border-brutal-border flex items-center justify-center mb-5 group-hover:rotate-6 transition-transform shadow-brutal-sm">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 !text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
               </svg>
            </div>
            <h3 class="text-lg font-extrabold mb-2 !text-slate-900">Tool AI Penghulu</h3>
            <p class="text-xs !text-slate-700 font-medium">Hasilkan prompt AI Khutbah Nikah, dll.</p>
          </div>
          <a href="/tools/prompt-penghulu" class="!text-slate-900 font-extrabold text-xs flex items-center gap-2 group-hover:gap-4 transition-all mt-4 uppercase tracking-wider">
            Open Tool <span class="text-lg">→</span>
          </a>
        </div>

        <!-- Right Side: Small Cards -->
        <div class="brutal-card p-6 flex flex-col justify-center text-center !bg-pink-200">
            <h4 class="text-4xl font-extrabold !text-slate-900">99+</h4>
            <p class="text-xs uppercase tracking-tighter !text-slate-700 font-extrabold">Prompts Generated</p>
        </div>

        <div class="brutal-card p-6 flex items-center gap-4 !bg-emerald-200">
            <div class="w-10 h-10 rounded-full bg-brutal-success border-2 border-brutal-border flex items-center justify-center shadow-brutal-sm">
                <div class="w-2 h-2 rounded-full bg-green-700 animate-pulse"></div>
            </div>
            <div>
                <p class="text-sm font-extrabold !text-slate-900">Server Status</p>
                <p class="text-xs !text-slate-700 font-bold">All systems operational</p>
            </div>
        </div>

        <!-- Prompt Generator -->
        <div class="md:col-span-2 brutal-card p-6 flex items-center gap-6" style="background-color: #c0b3ff; background-image: radial-gradient(#0f172a 1.5px, transparent 1.5px); background-size: 24px 24px;">
            <div class="flex-1">
                <h3 class="text-xl font-extrabold mb-2 !text-slate-900">AI Prompt Studio</h3>
                <p class="!text-slate-800 text-sm font-medium mb-4">Ciptakan prompt berkualitas tinggi untuk Gemini, ChatGPT, dan lainnya.</p>
                <a href="/tools/prompt-generator" class="brutal-btn brutal-btn-primary px-5 py-2 text-xs">Start Creating</a>
            </div>
            <div class="hidden md:block w-32 h-32 opacity-20 transform rotate-12">
                <svg viewBox="0 0 24 24" fill="currentColor" class="text-brutal-text">
                    <path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z" />
                </svg>
            </div>
        </div>
      </div>

      <!-- Ad Slot -->
      <AdSlot type="home" class="mt-32 -mb-20" />

      <!-- Recent Blog Feed -->
      <section class="mt-32">
        <div class="flex justify-between items-end mb-10">
            <div>
                <h2 class="text-3xl font-extrabold mb-2">Berita & Insights</h2>
                <p class="text-brutal-text-muted text-sm font-bold">Eksplorasi info nikah, berita, dan catatan lainnya.</p>
            </div>
            <a href="/blog" class="brutal-btn brutal-btn-outline px-5 py-2 text-xs hidden md:inline-flex">View Archive</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {latestPosts.slice(1, 4).map((post, index) => {
                // Skema warna berani (Bold Pastel) ala Xgrind
                const cardStyles = [
                  { 
                    card: '!bg-[#fae870]', // Kuning mencolok
                    icon: '!bg-[#fef08a]', 
                    tag: '!bg-white' 
                  },
                  { 
                    card: '!bg-[#c0e6ff]', // Biru muda cerah
                    icon: '!bg-[#7dd3fc]', 
                    tag: '!bg-[#bae6fd]' 
                  },
                  { 
                    card: '!bg-[#f8ddb2]', // Peach/Oranye terang
                    icon: '!bg-[#fdba74]', 
                    tag: '!bg-[#fcd34d]' 
                  }
                ];
                const style = cardStyles[index % cardStyles.length];
                
                return (
                <article class="h-full">
                    <a href={`/blog/${post.slug}`} class={`block h-full brutal-card overflow-hidden flex flex-col group ${style.card} transition-colors`}>
                        <!-- Top Image Area with Bottom Border -->
                        <div class="aspect-video relative p-0 border-b-3 border-brutal-border !bg-white overflow-hidden">
                             {post.image && (
                               typeof post.image === 'string' ? (
                                <img 
                                  src={post.image} 
                                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                                  alt={post.title} 
                                  loading="lazy"
                                />
                               ) : (
                                <Image 
                                  src={post.image} 
                                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                                  alt={post.title} 
                                  width={600}
                                  height={338}
                                  loading="lazy"
                                />
                               )
                             )}
                        </div>
                        
                        <!-- Content Area -->
                        <div class="p-6 flex flex-col flex-grow">
                            <!-- Icon & Title -->
                            <div class="flex items-start gap-3 mb-2">
                                <div class={`w-8 h-8 rounded-lg border-2 border-brutal-border flex items-center justify-center shrink-0 shadow-[2px_2px_0_#0f172a] group-hover:rotate-6 transition-transform ${style.icon}`}>
                                    <svg class="w-4 h-4 !text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                                    </svg>
                                </div>
                                <h3 class="text-lg font-extrabold group-hover:text-blue-700 transition-colors line-clamp-2 leading-tight !text-slate-900">{post.title}</h3>
                            </div>
                            
                            <!-- Description -->
                            <p class="!text-slate-800 line-clamp-2 text-xs leading-relaxed mb-6 flex-grow font-bold">{post.description}</p>
                            
                            <!-- Bottom Footer -->
                            <div class="flex justify-between items-end mt-auto">
                                <span class={`px-2.5 py-1 border-2 border-brutal-border rounded-full text-[9px] font-extrabold uppercase tracking-widest !text-slate-900 shadow-[2px_2px_0_#0f172a] dark:shadow-[2px_2px_0_#0f172a] ${style.tag}`}>
                                    {post.category}
                                </span>
                                
                                <span class="bg-[#131b2d] text-white px-4 py-2 rounded-full text-[11px] font-extrabold border-2 border-transparent group-hover:scale-105 transition-transform flex items-center gap-1.5">
                                    BACA <span>&rarr;</span>
                                </span>
                            </div>
                        </div>
                    </a>
                </article>
            )})}
        </div>
        <div class="md:hidden mt-8 text-center">
            <a href="/blog" class="brutal-btn brutal-btn-outline px-6 py-2 text-sm">View Archive</a>
        </div>
      </section>
    </Container>
  </main>
</Layout>
