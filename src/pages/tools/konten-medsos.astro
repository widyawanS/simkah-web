        // ── STATE ────────────────────────────────────────────────────────────────────
        let openId = null;
        const extras = {};      // { stepId: { key: value } }
        const jsonOpen = {};    // { stepId: bool }

        // ── HELPERS ──────────────────────────────────────────────────────────────────
        function cfg() {
            return {
                profesi: document.getElementById('profesi').value.trim() || 'profesi Anda',
                platform: document.getElementById('platform').value,
                audiens: document.getElementById('audiens').value.trim() || 'audiens Anda',
                niche: document.getElementById('niche').value.trim() || 'niche Anda',
            };
        }

        function buildPrompt(template, ex = {}) {
            const c = cfg();
            let t = template
                .replace(/\{profesi\}/g, c.profesi)
                .replace(/\{platform\}/g, c.platform)
                .replace(/\{audiens\}/g, c.audiens)
                .replace(/\{niche\}/g, c.niche);
            Object.entries(ex).forEach(([k, v]) => {
                t = t.replace(new RegExp(`\\{${k}\\}`, 'g'), v || `[${k} belum diisi]`);
            });
            t = t.replace(/\{[^}]+\}/g, m => `[${m.slice(1, -1)} belum diisi]`);
            return t;
        }

        function hlPrompt(text) {
            const c = cfg();
            const vars = [c.profesi, c.platform, c.audiens, c.niche].filter(x => x && x.length > 2);
            let out = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            vars.forEach(v => {
                const esc = v.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                out = out.replace(new RegExp(esc, 'g'), `<span class="var">${v}</span>`);
            });
            out = out.replace(/\[([^\]]+)\]/g, '<span class="fill">[$1]</span>');
            return out;
        }

        function buildJson(step) {
            const c = cfg();
            const ex = extras[step.id] || {};
            return {
                step: step.id,
                title: step.title,
                skills: step.skills,
                config: { profesi: c.profesi, platform: c.platform, audiens: c.audiens, niche: c.niche },
                requires_input: step.inputs.length > 0,
                input_fields: step.inputs.map(i => ({ key: i.key, value: ex[i.key] || null })),
                prompt: buildPrompt(step.template, ex)
            };
        }

        function hlJson(raw) {
            return raw
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/"([^"\n]+)":/g, '<span class="jk">"$1"</span>:')
                .replace(/: (\d+)/g, ': <span class="jn">$1</span>')
                .replace(/: (true|false|null)/g, ': <span class="jb">$1</span>')
                .replace(/: "([^"]*?)"/g, (m, v) => v.length > 60
                    ? `: <span class="jvs">"${v}"</span>`
                    : `: <span class="jv">"${v}"</span>`);
        }

        // ── RENDER ───────────────────────────────────────────────────────────────────
        function renderGrid() {
            const grid = document.getElementById('cardsGrid');
            grid.innerHTML = '';

            STEPS.forEach((step, i) => {
                // CARD
                const card = document.createElement('div');
                card.className = 'step-card' + (openId === step.id ? ' selected' : '');
                card.style.order = i * 2;
                card.innerHTML = `
      <div class="card-badge">✓</div>
      <div class="card-top">
        <span class="step-num">${String(step.id).padStart(2, '0')}</span>
        <span class="card-icon">${step.icon}</span>
      </div>
      <div class="card-title-sm">${step.title}</div>
      <div class="card-desc">${step.desc}</div>
    `;
                card.addEventListener('click', () => {
                    openId = openId === step.id ? null : step.id;
                    renderGrid();
                    if (openId) setTimeout(() => {
                        document.querySelector('.expand-panel')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }, 60);
                });
                grid.appendChild(card);

                // PANEL (spans full row)
                if (openId === step.id) {
                    const panel = buildPanel(step);
                    panel.style.order = i * 2 + 1;
                    grid.appendChild(panel);
                }
            });
        }

        function buildPanel(step) {
            const ex = extras[step.id] || {};
            const promptText = buildPrompt(step.template, ex);

            const panel = document.createElement('div');
            panel.className = 'expand-panel';

            // ── Build input fields HTML
            const inputsHTML = step.inputs.map(inp => `
    <div class="extra-field">
      <label>${inp.label}</label>
      <textarea data-key="${inp.key}" placeholder="${inp.placeholder}" rows="4">${ex[inp.key] || ''}</textarea>
    </div>
  `).join('');

            panel.innerHTML = `
    <div class="panel-header">
      <div class="panel-title">${step.icon} ${step.title}</div>
      <button class="panel-close">✕</button>
    </div>
    <div class="skill-tags">
      ${step.skills.map(s => `<span class="skill-tag">${s}</span>`).join('')}
    </div>
    <div class="panel-body">
      <div class="panel-left">
        ${inputsHTML}
        <div class="tip-box"><strong>💡 Tips:</strong><br>${step.tip}</div>
        <div class="panel-actions">
          <button class="btn btn-gold btn-copy-prompt">📋 Salin Prompt</button>
          <div class="btn-divider"></div>
          <button class="btn btn-green btn-copy-json">{ } Salin JSON</button>
          <button class="btn btn-outline-green btn-dl-json">⬇ JSON</button>
        </div>
        <div class="json-preview-wrap" id="jsonWrap_${step.id}">
          <div class="json-preview-label">Output JSON — Langkah ${step.id}</div>
          <div class="json-preview-box" id="jsonBox_${step.id}"></div>
        </div>
      </div>
      <div class="panel-right">
        <div class="preview-label">Preview Prompt</div>
        <div class="prompt-preview preview-area">${hlPrompt(promptText)}</div>
      </div>
    </div>
  `;

            // ── Close
            panel.querySelector('.panel-close').addEventListener('click', e => {
                e.stopPropagation();
                openId = null;
                renderGrid();
            });

            // ── Textarea live update
            panel.querySelectorAll('textarea[data-key]').forEach(ta => {
                ta.addEventListener('input', () => {
                    if (!extras[step.id]) extras[step.id] = {};
                    extras[step.id][ta.dataset.key] = ta.value;
                    const updated = buildPrompt(step.template, extras[step.id]);
                    panel.querySelector('.preview-area').innerHTML = hlPrompt(updated);
                    // If JSON preview is open, refresh it too
                    refreshJsonPreview(step, panel);
                });
            });

            // ── Salin Prompt
            panel.querySelector('.btn-copy-prompt').addEventListener('click', function () {
                const text = buildPrompt(step.template, extras[step.id] || {});
                navigator.clipboard.writeText(text).then(() => {
                    this.textContent = '✅ Tersalin!';
                    this.classList.add('success');
                    setTimeout(() => { this.innerHTML = '📋 Salin Prompt'; this.classList.remove('success'); }, 2200);
                });
            });

            // ── Salin JSON — toggle preview + copy
            panel.querySelector('.btn-copy-json').addEventListener('click', function () {
                const raw = JSON.stringify(buildJson(step), null, 2);
                const wrap = panel.querySelector(`#jsonWrap_${step.id}`);
                const box = panel.querySelector(`#jsonBox_${step.id}`);

                // Show/refresh preview
                box.innerHTML = hlJson(raw);
                box.dataset.raw = raw;
                wrap.classList.add('open');

                // Copy to clipboard
                navigator.clipboard.writeText(raw).then(() => {
                    this.textContent = '✅ JSON Tersalin!';
                    this.classList.add('success');
                    setTimeout(() => { this.innerHTML = '{ } Salin JSON'; this.classList.remove('success'); }, 2400);
                });
            });

            // ── Download JSON
            panel.querySelector('.btn-dl-json').addEventListener('click', function () {
                const c = cfg();
                const raw = JSON.stringify(buildJson(step), null, 2);
                const blob = new Blob([raw], { type: 'application/json' });
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = `prompt_step${step.id}_${c.profesi}_${c.platform.replace(/[\s/]/g, '_')}.json`;
                a.click();
                this.textContent = '✅ Downloaded';
                this.classList.add('success');
                setTimeout(() => { this.innerHTML = '⬇ JSON'; this.classList.remove('success'); }, 2200);
            });

            // ── Mark done
            panel.querySelector('.panel-close') // reuse close listener above

            return panel;
        }

        function refreshJsonPreview(step, panel) {
            const wrap = panel.querySelector(`#jsonWrap_${step.id}`);
            const box = panel.querySelector(`#jsonBox_${step.id}`);
            if (wrap && wrap.classList.contains('open') && box) {
                const raw = JSON.stringify(buildJson(step), null, 2);
                box.innerHTML = hlJson(raw);
                box.dataset.raw = raw;
            }
        }

        // ── LIVE CONFIG UPDATE ────────────────────────────────────────────────────────
        ['profesi', 'platform', 'audiens', 'niche'].forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                if (openId) {
                    // Patch live without full re-render for smoothness
                    const step = STEPS.find(s => s.id === openId);
                    const preview = document.querySelector('.preview-area');
                    if (step && preview) {
                        const updated = buildPrompt(step.template, extras[openId] || {});
                        preview.innerHTML = hlPrompt(updated);
                        const panel = document.querySelector('.expand-panel');
                        if (panel) refreshJsonPreview(step, panel);
                    }
                } else {
                    renderGrid();
                }
            });
        });

        // ── INIT ─────────────────────────────────────────────────────────────────────
        renderGrid();
    
</script>
