---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import ConverterComponent from "@components/tools/Converter";
import AdSlot from "@components/ui/AdSlot.astro";
---

<Layout title="Image & Media Converter - Pro Version">
  <Container>
    <div class="pt-0 pb-16 md:pb-24 animate-fade-in min-h-screen">
              <div class="text-center mb-16 mt-12 flex flex-col items-center">
        <span class="inline-block px-4 py-2 brutal-badge bg-[#bbf7d0] text-brutal-text text-sm font-bold mb-4 border-2 border-brutal-border">
          ⚡ Premium Tool
        </span>
        <h1 class="text-3xl md:text-5xl font-black text-brutal-text text-center mb-4 drop-shadow-md">
          Media <span class="text-indigo-500">Converter</span>
        </h1>
        <p class="text-center text-brutal-text-muted max-w-2xl mx-auto mb-8 text-lg font-medium">
          Konversi gambar HEIC, JPG, PNG, dan WebP Anda secara instan. Semua proses dilakukan di browser Anda untuk privasi maksimal.
        </p>
        <AdSlot type="tools" />
      </div>
        
        <div class="max-w-4xl mx-auto">
            <ConverterComponent client:load />
        </div>
    </div>
  </Container>
</Layout>

