---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import AdSlot from "@components/ui/AdSlot.astro";
import { getAllTools } from "@lib/keystatic";

// Get all tools from Keystatic
const allTools = await getAllTools();

const getToolCategoryColor = (cat: string) => {
  const c = cat?.toLowerCase() || '';
  if (c === 'calculator') return '!bg-[#c0e6ff] !text-slate-900 shadow-[2px_2px_0_#0f172a]';
  if (c === 'generator') return '!bg-[#fae870] !text-slate-900 shadow-[2px_2px_0_#0f172a]';
  if (c === 'converter') return '!bg-pink-200 !text-slate-900 shadow-[2px_2px_0_#0f172a]';
  return '!bg-emerald-200 !text-slate-900 shadow-[2px_2px_0_#0f172a]';
};
---

<Layout title="Tools - Kumpulan Alat Produktivitas">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Tools & Calculators</Fragment>
      <Fragment slot="desc">Kumpulan alat produktivitas untuk membantu perencanaan Anda</Fragment>
    </Sectionhead>

    <AdSlot type="tools" />

    <div class="grid md:grid-cols-2 gap-6 mt-16 max-w-5xl mx-auto">
      <!-- Hardcoded: Penelusuran Perkara -->
      <a 
        href="/tools/penelusuran-perkara" 
        class="group relative brutal-card dark:bg-brutal-card rounded-3xl p-8 transition-all duration-300 bg-emerald-200 hover:-translate-y-1 hover:shadow-brutal-lg">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl mb-6 bg-emerald-500/10 border border-emerald-500/30">
          ⚖️
        </div>
        <h3 class="text-2xl font-bold mb-3 transition-colors !text-slate-900 group-hover:text-emerald-700">
          Penelusuran Perkara
        </h3>
        <p class="!text-slate-800 leading-relaxed font-bold">
          Cari informasi perkara dari seluruh Pengadilan Agama dan Mahkamah Syar'iyah di Indonesia langsung dari SIPP.
        </p>
        <div class="mt-4 flex items-center gap-2">
          <span class="text-[10px] px-3 py-1 rounded-full font-extrabold uppercase tracking-widest border-2 border-brutal-border !bg-emerald-200 !text-slate-900 shadow-[2px_2px_0_#0f172a]">
            lookup
          </span>
        </div>
        <div class="mt-4 flex items-center gap-2 text-sm font-bold !text-slate-900 group-hover:text-emerald-700 transition-colors">
          <span>Buka Tool</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>
      </a>

      {allTools.map((tool, i) => {
        const bgColors = ['bg-[#fae870]', 'bg-[#c0e6ff]', 'bg-[#f8ddb2]', 'bg-[#e8dff5]', 'bg-[#bbf7d0]', 'bg-[#ffcdd2]'];
        const cardBg = bgColors[i % bgColors.length];
        return (
        <a 
          href={tool?.isActive ? tool?.link : "#"} 
          class:list={[
            "group relative brutal-card dark:bg-brutal-card rounded-3xl p-8 transition-all duration-300",
            cardBg,
            !tool?.isActive ? "opacity-60 cursor-not-allowed" : "hover:-translate-y-1 hover:shadow-brutal-lg"
          ]}>
          
          {!tool?.isActive && (
            <span class="absolute top-4 right-4 px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest bg-slate-900 text-white rounded-full border-2 border-brutal-border shadow-[2px_2px_0_#0f172a]">
              Coming Soon
            </span>
          )}
          
          <div class={`w-16 h-16 rounded-2xl flex items-center justify-center text-3xl mb-6 bg-${tool?.colorFrom?.split('-')[0] || 'indigo'}-500/10 border border-${tool?.colorFrom?.split('-')[0] || 'indigo'}-500/30`}>
            {tool?.icon || '🔧'}
          </div>
          
          <h3 class:list={[
            "text-2xl font-bold mb-3 transition-colors !text-slate-900",
            tool?.isActive && "group-hover:text-blue-700"
          ]}>
            {tool?.title || tool?.slug || 'Tool'}
          </h3>
          
          <p class="!text-slate-800 leading-relaxed font-bold">
            {tool?.shortDescription || 'Deskripsi tool'}
          </p>

          <div class="mt-4 flex items-center gap-2">
            <span class={`text-[10px] px-3 py-1 rounded-full font-extrabold uppercase tracking-widest border-2 border-brutal-border ${getToolCategoryColor(tool?.category || 'other')}`}>
              {tool?.category || 'other'}
            </span>
          </div>
          
          {tool?.isActive && (
            <div class="mt-4 flex items-center gap-2 text-sm font-bold !text-slate-900 group-hover:text-blue-700 transition-colors">
              <span>Buka Tool</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          )}
        </a>
        );
      })}
    </div>

    <!-- Stats Section -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
      <div class=" brutal-card bg-[#fae870] dark:bg-brutal-card  rounded-2xl p-6 text-center">
        <p class="text-4xl font-bold text-gradient">{allTools.filter(t => t?.isActive).length}</p>
        <p class="text-sm text-brutal-text-muted dark:text-slate-400 mt-1">Active Tools</p>
      </div>
      <div class=" brutal-card bg-[#c0e6ff] dark:bg-brutal-card  rounded-2xl p-6 text-center">
        <p class="text-4xl font-bold text-gradient">100%</p>
        <p class="text-sm text-brutal-text-muted dark:text-slate-400 mt-1">Free to Use</p>
      </div>
      <div class=" brutal-card bg-[#f8ddb2] dark:bg-brutal-card  rounded-2xl p-6 text-center">
        <p class="text-4xl font-bold text-gradient">0</p>
        <p class="text-sm text-brutal-text-muted dark:text-slate-400 mt-1">Data Upload</p>
      </div>
      <div class=" brutal-card bg-[#e8dff5] dark:bg-brutal-card  rounded-2xl p-6 text-center">
        <p class="text-4xl font-bold text-gradient">∞</p>
        <p class="text-sm text-brutal-text-muted dark:text-slate-400 mt-1">Calculations</p>
      </div>
    </div>
  </Container>
</Layout>
