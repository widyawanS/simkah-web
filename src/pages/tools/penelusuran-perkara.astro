---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import AdSlot from "@components/ui/AdSlot.astro";

const SHEET_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRphPEFpPWt1xyQNyukVHMS9g8kCmq99CjcRx_YitDAtc_SKmBDIqambYVjwq2Lvr05GW3i-OuGotd_/pub?output=csv";

let allCourts: any[] = [];
try {
  const response = await fetch(SHEET_URL);
  const csvData = await response.text();
  const rows = csvData.split('\n').filter(row => row.trim() !== '');
  const headers = rows[0].split(',').map(h => h.trim());
  allCourts = rows.slice(1).map(row => {
    const values = row.split(',');
    let obj: Record<string, string> = {};
    headers.forEach((header, i) => {
      obj[header] = values[i]?.trim() || '';
    });
    return obj;
  }).filter((c: any) => c['Sipp PA'] && c['Sipp PA'] !== '' && c['Sipp PA'] !== '-');
} catch (error) {
  // silently fail, UI will show empty
}
---

<Layout title="Penelusuran Perkara SIPP - Cari Info Perkara Pengadilan Agama">
  <Container>
    <div class="max-w-6xl mx-auto mb-20">
      <!-- Header -->
      <div class="text-center mb-12 mt-12 flex flex-col items-center">
        <span class="inline-block px-4 py-2 brutal-badge bg-emerald-200 text-brutal-text text-sm font-bold mb-4 border-2 border-brutal-border">
          ⚖️ Penelusuran Perkara
        </span>
        <h1 class="text-3xl md:text-5xl font-black text-brutal-text text-center mb-4 drop-shadow-md">
          Penelusuran Perkara <span class="text-emerald-600">SIPP</span>
        </h1>
        <p class="text-center text-brutal-text-muted max-w-2xl mx-auto mb-8 text-lg font-medium">
          Pilih pengadilan untuk membuka Sistem Informasi Penelusuran Perkara (SIPP) langsung dari sini.
        </p>
        <AdSlot type="tools" />
      </div>

      <!-- Court Selection Card -->
      <div class="brutal-card bg-[#c0e6ff] dark:bg-brutal-card rounded-3xl p-8 md:p-10 mb-6">
        <div class="space-y-4">
          <!-- Court Selection -->
          <div>
            <label class="block text-sm font-bold text-brutal-text dark:text-white mb-2">
              Pilih Pengadilan
            </label>
            <div class="relative" id="courtDropdown">
              <input
                type="text"
                id="courtSearch"
                placeholder="Ketik nama Pengadilan Agama atau MS..."
                autocomplete="off"
                class="brutal-input bg-white dark:bg-slate-800"
              />
              <input type="hidden" id="courtUrl" name="courtUrl" />
              <input type="hidden" id="courtName" name="courtName" />
              <div id="courtList" class="absolute z-50 w-full mt-1 bg-white dark:bg-slate-800 border-2 border-brutal-border rounded-xl shadow-lg max-h-60 overflow-y-auto hidden">
              </div>
            </div>
            <p id="courtHint" class="text-xs text-slate-500 mt-1">
              Contoh: PA Bandung, MS Banda Aceh
            </p>
          </div>

          <!-- Action Buttons -->
          <div class="flex gap-3">
            <button
              type="button"
              id="loadBtn"
              class="brutal-btn brutal-btn-primary flex-1 py-3 text-lg font-bold flex items-center justify-center gap-2"
              disabled
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              Buka SIPP
            </button>
            <a
              id="openTabBtn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="brutal-btn bg-white dark:bg-slate-700 text-brutal-text dark:text-white py-3 px-6 text-lg font-bold flex items-center gap-2 border-2 border-brutal-border hover:bg-slate-100 dark:hover:bg-slate-600 transition-colors hidden"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Tab Baru
            </a>
          </div>
        </div>
      </div>

      <!-- Iframe Container -->
      <div id="iframeContainer" class="hidden">
        <div class="brutal-card bg-white dark:bg-brutal-card rounded-3xl overflow-hidden border-2 border-brutal-border">
          <!-- Iframe Header -->
          <div class="flex items-center justify-between px-6 py-3 bg-slate-800 text-white">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <span id="iframeTitle" class="text-sm font-semibold text-slate-300 truncate max-w-md">SIPP</span>
            </div>
            <div class="flex items-center gap-2">
              <button id="reloadBtn" type="button" class="p-1.5 hover:bg-slate-700 rounded-lg transition-colors" title="Muat ulang">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </button>
              <a id="externalLink" href="#" target="_blank" rel="noopener noreferrer" class="p-1.5 hover:bg-slate-700 rounded-lg transition-colors" title="Buka di tab baru">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Loading Overlay -->
          <div id="iframeLoading" class="absolute inset-0 bg-white dark:bg-slate-900 flex items-center justify-center z-10" style="top: 44px;">
            <div class="text-center">
              <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-brutal-border border-t-emerald-500 mb-3"></div>
              <p class="text-sm font-bold text-brutal-text dark:text-white">Memuat SIPP...</p>
              <p class="text-xs text-slate-500">Mohon tunggu sebentar</p>
            </div>
          </div>

          <!-- The Iframe -->
          <iframe
            id="sippFrame"
            class="w-full border-0"
            style="height: 70vh; min-height: 500px;"
            loading="lazy"
            sandbox="allow-same-origin allow-scripts allow-forms allow-popups"
            title="SIPP - Sistem Informasi Penelusuran Perkara"
          ></iframe>
        </div>
      </div>

      <!-- Empty State (before selection) -->
      <div id="emptyState" class="text-center py-16">
        <div class="text-6xl mb-4">⚖️</div>
        <h3 class="text-xl font-bold text-brutal-text dark:text-white mb-2">Pilih Pengadilan</h3>
        <p class="text-slate-500 max-w-md mx-auto">
          Pilih pengadilan di atas untuk membuka SIPP. Anda bisa mencari perkara langsung di halaman SIPP.
        </p>
      </div>

      <!-- Info Box -->
      <div class="mt-8 brutal-card bg-slate-100 dark:bg-slate-800/50 rounded-2xl p-6">
        <h3 class="font-bold text-brutal-text dark:text-white mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Informasi
        </h3>
        <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
          <li>• Halaman SIPP dimuat langsung dari server pengadilan melalui iframe.</li>
          <li>• Anda bisa mencari nomor perkara langsung di kolom pencarian SIPP.</li>
          <li>• Jika iframe tidak muncul, klik "Tab Baru" untuk membuka langsung.</li>
          <li>• Nama pihak mungkin disamarkan oleh pengadilan untuk privasi.</li>
        </ul>
      </div>
    </div>
  </Container>
</Layout>

<script is:inline define:vars={{ courts: allCourts }}>
  const courtSearch = document.getElementById('courtSearch');
  const courtList = document.getElementById('courtList');
  const courtUrl = document.getElementById('courtUrl');
  const courtName = document.getElementById('courtName');
  const courtHint = document.getElementById('courtHint');
  const loadBtn = document.getElementById('loadBtn');
  const openTabBtn = document.getElementById('openTabBtn');
  const iframeContainer = document.getElementById('iframeContainer');
  const iframeTitle = document.getElementById('iframeTitle');
  const sippFrame = document.getElementById('sippFrame');
  const iframeLoading = document.getElementById('iframeLoading');
  const externalLink = document.getElementById('externalLink');
  const reloadBtn = document.getElementById('reloadBtn');
  const emptyState = document.getElementById('emptyState');

  let selectedCourt = null;

  // Populate court list
  function renderCourtList(filter = '') {
    const lower = filter.toLowerCase();
    const filtered = courts.filter(c => {
      const name = (c['Nama PA'] || '').toLowerCase();
      return name.includes(lower);
    });

    courtList.innerHTML = '';
    if (filtered.length === 0) {
      courtList.innerHTML = '<div class="px-4 py-3 text-sm text-slate-500">Tidak ditemukan</div>';
    } else {
      filtered.forEach(court => {
        const div = document.createElement('div');
        div.className = 'px-4 py-3 cursor-pointer hover:bg-emerald-100 dark:hover:bg-slate-700 text-sm transition-colors border-b border-slate-100 dark:border-slate-700 last:border-0';
        div.textContent = court['Nama PA'] || '';
        div.addEventListener('click', () => {
          courtSearch.value = court['Nama PA'] || '';
          courtUrl.value = court['Sipp PA'] || '';
          courtName.value = court['Nama PA'] || '';
          selectedCourt = court;
          courtList.classList.add('hidden');
          courtHint.textContent = '✓ Pengadilan dipilih';
          courtHint.classList.add('text-emerald-600');
          loadBtn.disabled = false;
          openTabBtn.classList.remove('hidden');
          openTabBtn.href = court['Sipp PA'] || '#';
        });
        courtList.appendChild(div);
      });
    }
  }

  // Show/hide dropdown
  courtSearch.addEventListener('focus', () => {
    renderCourtList(courtSearch.value);
    courtList.classList.remove('hidden');
  });

  courtSearch.addEventListener('input', () => {
    courtUrl.value = '';
    courtName.value = '';
    selectedCourt = null;
    courtHint.textContent = 'Ketik nama Pengadilan Agama atau MS...';
    courtHint.classList.remove('text-emerald-600');
    loadBtn.disabled = true;
    openTabBtn.classList.add('hidden');
    renderCourtList(courtSearch.value);
    courtList.classList.remove('hidden');
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('courtDropdown').contains(e.target)) {
      courtList.classList.add('hidden');
    }
  });

  // Load SIPP in iframe
  function loadSipp() {
    const url = courtUrl.value;
    const name = courtName.value || 'SIPP';

    if (!url) {
      alert('Silakan pilih pengadilan terlebih dahulu.');
      return;
    }

    // Hide empty state, show iframe
    emptyState.classList.add('hidden');
    iframeContainer.classList.remove('hidden');
    iframeLoading.classList.remove('hidden');

    // Update header
    iframeTitle.textContent = name;
    externalLink.href = url;

    // Load in iframe
    sippFrame.src = url;
  }

  // Iframe load complete
  sippFrame.addEventListener('load', () => {
    iframeLoading.classList.add('hidden');
  });

  // Iframe error
  sippFrame.addEventListener('error', () => {
    iframeLoading.classList.add('hidden');
  });

  // Buttons
  loadBtn.addEventListener('click', loadSipp);

  reloadBtn.addEventListener('click', () => {
    if (courtUrl.value) {
      iframeLoading.classList.remove('hidden');
      sippFrame.src = courtUrl.value;
    }
  });
</script>
