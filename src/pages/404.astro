---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="404 Not Found">
  <Container>
    <div class="min-h-[calc(100vh-16rem)] flex items-center justify-center">
      <div class="mt-16 text-center">
        <div class="brutal-card inline-block p-12 mb-8 bg-brutal-accent/30">
          <h1 class="text-8xl lg:text-9xl font-extrabold tracking-tighter">404</h1>
        </div>
        <p class="text-lg mt-4 text-brutal-text-muted font-bold">Halaman tidak ditemukan.</p>
        <a href="/" class="brutal-btn brutal-btn-primary px-6 py-3 mt-6 inline-flex text-sm">
          ← Kembali ke Home
        </a>
      </div>
    </div>
  </Container>
</Layout>
