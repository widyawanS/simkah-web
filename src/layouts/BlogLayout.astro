---
import Container from "@components/container.astro";
import { getFormattedDate, getBadgeColor } from "@utils/all";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <Container>
    <div class="mx-auto max-w-[735px] mt-14">
      <span class={`brutal-badge ${getBadgeColor(frontmatter.category)} mb-4`}>
        {frontmatter.category}
      </span>
      <h1
        class="text-3xl lg:text-4xl font-extrabold lg:tracking-tight mt-1 lg:leading-tight">
        {frontmatter.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-brutal-text-muted font-bold">
          {frontmatter.author}
        </span>
        <span class="text-brutal-text-muted">•</span>
        <time class="text-brutal-text-muted" datetime={frontmatter.publishDate}>
          {getFormattedDate(frontmatter.publishDate)}
        </time>
        <span class="text-brutal-text-muted hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            frontmatter.tags.map((tag) => (
              <span class="brutal-badge bg-brutal-accent text-xs">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6 prose-headings:font-extrabold text-brutal-text">
      <slot />
    </div>
    <div class="text-center mt-12 mb-12">
      <a
        href="/blog"
        class="brutal-btn brutal-btn-outline px-6 py-3 text-sm"
        >← Back to Archive</a
      >
    </div>
  </Container>
</Layout>
