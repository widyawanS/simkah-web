---
import { getSiteSettings } from "@lib/keystatic";
import Container from "./container.astro";

const settings = await getSiteSettings();
const footer: any = settings?.footer || {};
const year = new Date().getFullYear();
---

<footer class="mt-32 pb-12 border-t-3 border-brutal-border pt-20">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      <!-- Left: Profile & Social -->
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-extrabold mb-4">SIMKAH.WEB.ID</h3>
          <p class="text-brutal-text-muted text-sm leading-relaxed">
            {footer.profile || "Selamat datang di portal informasi SIMKAH dan alat bantu manajemen pernikahan."}
          </p>
        </div>
        <div>
          <h4 class="text-sm font-extrabold uppercase tracking-widest text-brutal-text-muted mb-4">Location</h4>
          <p class="text-brutal-text-muted text-sm whitespace-pre-line">
            {footer.address || "Jl. Kebon Sirih No. 123,\nJakarta Pusat, Indonesia"}
          </p>
        </div>
        <div class="flex items-center gap-4">
          {footer.whatsapp && (
            <a href={footer.whatsapp.startsWith('http') ? footer.whatsapp : `https://wa.me/${footer.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-success text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              WA
            </a>
          )}
          {footer.telegram && (
            <a href={footer.telegram.startsWith('http') ? footer.telegram : `https://t.me/${footer.telegram.replace('@', '')}`} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-info text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              TG
            </a>
          )}
          {footer.facebook && (
            <a href={footer.facebook} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-primary text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              FB
            </a>
          )}
          {footer.instagram && (
            <a href={footer.instagram} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-accent text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              IG
            </a>
          )}
        </div>
      </div>

      <!-- Middle: Pages -->
      <div class="flex flex-col items-start md:items-center">
        <div class="w-full max-w-[200px]">
          <h3 class="text-lg font-extrabold mb-6">Quick Links</h3>
          <ul class="space-y-4">
            <li><a href="/about" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">About Me</a></li>
            <li><a href="/disclaimer" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Disclaimer</a></li>
            <li><a href="/privacy-policy" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Privacy Policy</a></li>
            <li><a href="/contact" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Contact Support</a></li>
          </ul>
        </div>
      </div>

      <!-- Right: Twitter Embed -->
      <div>
        <div class="brutal-card p-6 h-[400px] flex flex-col relative overflow-hidden group">
          <div class="absolute -top-12 -right-12 w-32 h-32 bg-brutal-primary/20 rounded-full blur-3xl group-hover:bg-brutal-primary/40 transition-all"></div>
          <div class="relative z-10 flex flex-col h-full">
            <div class="flex items-center gap-3 mb-4 shrink-0">
              <div class="w-10 h-10 bg-brutal-info border-[3px] border-brutal-border rounded-full flex items-center justify-center text-brutal-text group-hover:rotate-6 transition-transform shadow-brutal-sm">
                <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </div>
              <h4 class="text-sm font-extrabold uppercase tracking-widest text-brutal-text">Posts on X</h4>
            </div>
            
            <div class="flex-1 overflow-y-auto min-h-0 relative z-10 twitter-container" id="twitter-timeline-container">
              <!-- Twitter timeline will be dynamically loaded here with matching theme -->
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      function loadTwitterWidget() {
        const container = document.getElementById('twitter-timeline-container');
        if (!container) return;

        // Clear container to allow re-render on theme/page changes
        container.innerHTML = '';

        const isDark = document.documentElement.classList.contains('dark');
        
        const anchor = document.createElement('a');
        anchor.className = 'twitter-timeline';
        anchor.setAttribute('data-height', '310');
        anchor.setAttribute('data-theme', isDark ? 'dark' : 'light');
        anchor.setAttribute('data-chrome', 'transparent noheader nofooter noborders');
        anchor.setAttribute('data-link-color', isDark ? '#fb7185' : '#e85d75');
        anchor.href = 'https://x.com/cakwied?ref_src=twsrc%5Etfw';
        anchor.textContent = 'Posts by cakwied';
        
        container.appendChild(anchor);

        if (window.twttr && window.twttr.widgets) {
          window.twttr.widgets.load(container);
        } else {
          // Avoid loading duplicate scripts if already present
          if (!document.getElementById('twitter-wjs')) {
            const script = document.createElement('script');
            script.id = 'twitter-wjs';
            script.src = 'https://platform.x.com/widgets.js';
            script.async = true;
            script.charset = 'utf-8';
            document.head.appendChild(script);
          }
        }

        // Fallback UI check: If widget doesn't load within 3 seconds, show a styled fallback button
        setTimeout(() => {
          const iframe = container.querySelector('iframe');
          if (!iframe) {
            container.innerHTML = `
              <div class="flex flex-col items-center justify-center h-full text-center p-2">
                <p class="text-xs text-brutal-text-muted mb-4 font-bold leading-relaxed">
                  Timeline X tidak dapat dimuat otomatis (memerlukan login X di browser atau terhalang ad-blocker).
                </p>
                <a href="https://x.com/cakwied" target="_blank" class="w-full brutal-btn bg-brutal-secondary text-white py-3 text-xs font-extrabold uppercase tracking-wider">
                  Kunjungi @cakwied di X
                </a>
              </div>
            `;
          }
        }, 3000);
      }

      // Initial execution
      loadTwitterWidget();
      
      // Re-run on Astro view transition swaps
      document.addEventListener('astro:after-swap', loadTwitterWidget);

      // Listen to theme switches to live-reload matching theme
      if (!window.twitterObserverAttached) {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class') {
              loadTwitterWidget();
            }
          });
        });
        observer.observe(document.documentElement, { attributes: true });
        window.twitterObserverAttached = true;
      }
    </script>

    <div class="pt-12 border-t-3 border-brutal-border flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-xs text-brutal-text-muted text-center md:text-left font-bold">
        © {year} SIMKAH.WEB.ID | All rights reserved. <br class="md:hidden" /> Bagian dari inisiatif digital keluarga Sakinah.
      </p>
      <div class="flex items-center gap-6 text-[10px] font-extrabold uppercase tracking-widest text-brutal-text-muted">
        <span>Build with Astro 5.0</span>
        <span>by <a href="https://saicreative.biz.id" target="_blank" class="hover:text-brand-primary transition-colors">saicreative</a></span>
      </div>
    </div>
  </Container>
</footer>
