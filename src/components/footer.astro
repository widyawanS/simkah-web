---
import { getSiteSettings } from "@lib/keystatic";
import Container from "./container.astro";

const settings = await getSiteSettings();
const footer: any = settings?.footer || {};
const year = new Date().getFullYear();
---

<footer class="mt-32 pb-12 border-t-3 border-brutal-border pt-20">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      <!-- Left: Profile & Social -->
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-extrabold mb-4">SIMKAH.WEB.ID</h3>
          <p class="text-brutal-text-muted text-sm leading-relaxed">
            {footer.profile || "Selamat datang di portal informasi SIMKAH dan alat bantu manajemen pernikahan."}
          </p>
        </div>
        <div>
          <h4 class="text-sm font-extrabold uppercase tracking-widest text-brutal-text-muted mb-4">Location</h4>
          <p class="text-brutal-text-muted text-sm whitespace-pre-line">
            {footer.address || "Jl. Kebon Sirih No. 123,\nJakarta Pusat, Indonesia"}
          </p>
        </div>
        <div class="flex items-center gap-4">
          {footer.whatsapp && (
            <a href={footer.whatsapp.startsWith('http') ? footer.whatsapp : `https://wa.me/${footer.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-success text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              WA
            </a>
          )}
          {footer.telegram && (
            <a href={footer.telegram.startsWith('http') ? footer.telegram : `https://t.me/${footer.telegram.replace('@', '')}`} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-info text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              TG
            </a>
          )}
          {footer.facebook && (
            <a href={footer.facebook} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-primary text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              FB
            </a>
          )}
          {footer.instagram && (
            <a href={footer.instagram} target="_blank" class="brutal-btn w-10 h-10 bg-brutal-accent text-brutal-text p-0 flex items-center justify-center text-xs font-extrabold">
              IG
            </a>
          )}
        </div>
      </div>

      <!-- Middle: Pages -->
      <div class="flex flex-col items-start md:items-center">
        <div class="w-full max-w-[200px]">
          <h3 class="text-lg font-extrabold mb-6">Quick Links</h3>
          <ul class="space-y-4">
            <li><a href="/about" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">About Me</a></li>
            <li><a href="/disclaimer" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Disclaimer</a></li>
            <li><a href="/privacy-policy" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Privacy Policy</a></li>
            <li><a href="/contact" class="text-brutal-text-muted hover:text-brand-primary transition-colors text-sm font-bold">Contact Support</a></li>
          </ul>
        </div>
      </div>

      <!-- Right: Twitter/X Profile Card -->
      <div>
        <div class="brutal-card p-6 h-fit flex flex-col relative overflow-visible group">
          <!-- Floating Badge -->
          <div class="absolute -top-3 -right-3 bg-brutal-accent border-3 border-brutal-border px-2.5 py-1.5 rounded-brutal shadow-brutal-sm text-[9px] font-black text-brutal-text uppercase tracking-wider flex items-center gap-1.5 rotate-6 group-hover:rotate-12 transition-transform animate-badge-float z-20">
            <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>Posts on X</span>
          </div>

          <div class="absolute -top-12 -right-12 w-32 h-32 bg-brutal-primary/20 rounded-full blur-3xl group-hover:bg-brutal-primary/40 transition-all"></div>
          
          <div class="relative z-10 flex flex-col h-full justify-between flex-grow">
            <!-- Profile Info -->
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <img 
                  src="/images/cakwied.jpg" 
                  alt="cakwied profile" 
                  width="48"
                  height="48"
                  class="w-12 h-12 rounded-full border-3 border-brutal-border shadow-brutal-sm object-cover bg-white"
                />
                <div>
                  <h5 class="font-extrabold text-sm text-brutal-text flex items-center gap-1">
                    <span>Widyawan Sigitmanto</span>
                    <svg class="w-4 h-4 text-[#1d9bf0] fill-current shrink-0" viewBox="0 0 24 24" aria-label="Verified account">
                      <path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.99-3.818-3.99-.48 0-.94.1-1.348.27C14.825 2.515 13.512 1.5 12 1.5s-2.825 1.015-3.422 2.28c-.407-.17-.867-.27-1.348-.27-2.108 0-3.818 1.78-3.818 3.99 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.58.875 2.95 2.148 3.6-.154.435-.238.905-.238 1.4 0 2.21 1.71 3.99 3.818 3.99.48 0 .94-.1 1.348-.27.597 1.265 1.91 2.28 3.422 2.28s2.825-1.015 3.422-2.28c.407.17.867.27 1.348.27 2.108 0 3.818-1.78 3.818-3.99 0-.495-.084-.965-.238-1.4 1.273-.65 2.148-2.02 2.148-3.6zm-12.72 3.32l-3.32-3.32 1.42-1.42 1.9 1.9 4.7-4.7 1.42 1.42-6.12 6.12z"/>
                    </svg>
                  </h5>
                  <p class="text-xs text-brutal-text-muted font-bold">@cakwied</p>
                </div>
              </div>
              
              <p class="text-[11px] text-brutal-text-muted leading-relaxed font-bold">
                Penghulu Pinggiran (Konsultasi Nikah DM-free) | Belajar AI & Automation.
                Memanfaatkan IT biar lebih efektif & produktif. Dokumentasi perjalanan belajar saya.
              </p>
            </div>
            
            <div class="space-y-2 mt-6">
              <a 
                href="https://x.com/cakwied" 
                target="_blank" 
                class="w-full brutal-btn bg-brutal-secondary text-white py-4 text-xs font-black uppercase tracking-wider text-center block shadow-[2px_2px_0_var(--brutal-border-color)] hover:-translate-y-0.5 active:translate-y-0 transition-all"
              >
                Kunjungi @cakwied di X
              </a>
              <span class="text-[9px] text-center block text-brutal-text-muted font-bold">
                Membuka langsung di tab baru (Aman & Bebas Blokir)
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t-3 border-brutal-border flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-xs text-brutal-text-muted text-center md:text-left font-bold">
        © {year} SIMKAH.WEB.ID | All rights reserved. <br class="md:hidden" /> Bagian dari inisiatif digital keluarga Sakinah.
      </p>
      <div class="flex items-center gap-6 text-[10px] font-extrabold uppercase tracking-widest text-brutal-text-muted">
        <span>Build with Astro 5.0</span>
        <span>by <a href="https://saicreative.biz.id" target="_blank" class="hover:text-brand-primary transition-colors">saicreative</a></span>
      </div>
    </div>
  </Container>
</footer>

<style>
  @keyframes badge-float {
    0%, 100% {
      transform: translateY(0) rotate(6deg);
    }
    50% {
      transform: translateY(-4px) rotate(6deg);
    }
  }
  .animate-badge-float {
    animation: badge-float 3s ease-in-out infinite;
  }
</style>
