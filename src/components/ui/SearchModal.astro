<div id="search-modal" class="fixed inset-0 z-[60] flex items-start justify-center pt-[10vh] px-4 bg-slate-950/80 backdrop-blur-sm hidden animate-fade-in">
  <div class="w-full max-w-2xl bg-white dark:bg-slate-900 rounded-3xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-800 animate-slide-up">
    <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input 
        type="text" 
        id="search-input" 
        placeholder="Cari artikel atau tool..." 
        class="flex-1 bg-transparent border-none outline-none text-xl text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500"
        autocomplete="off"
      />
      <button id="close-search" class="text-sm font-bold text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">ESC</button>
    </div>

    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-4 space-y-2">
      <p class="text-center py-8 text-slate-500">Mulai mengetik untuk mencari...</p>
    </div>

    <div class="p-4 bg-slate-100 dark:bg-slate-950/80 border-t border-slate-200 dark:border-slate-800 text-[11px] text-slate-600 dark:text-slate-400 flex justify-between">
      <span>Gunakan tombol panah untuk navigasi</span>
      <span>Cepat & Ringan</span>
    </div>
  </div>
</div>

<script is:inline>
  var fuseSearchInstance = null;

  async function loadFuseJS() {
    if (window.Fuse) return window.Fuse;
    return new Promise((resolve) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/fuse.js@7.0.0';
      script.onload = () => resolve(window.Fuse);
      document.head.appendChild(script);
    });
  }

  function setupSearch() {
    var searchBtns = document.querySelectorAll('.search-btn-trigger');
    var searchModal = document.getElementById('search-modal');
    var closeSearch = document.getElementById('close-search');
    var searchInput = document.getElementById('search-input');
    var searchResults = document.getElementById('search-results');

    if (!searchModal) return;

    async function getSearchData() {
      try {
        var FuseLib = await loadFuseJS();
        var response = await fetch('/search.json');
        var data = await response.json();
        
        fuseSearchInstance = new FuseLib(data, {
          keys: ['title', 'description', 'category'],
          threshold: 0.4
        });
      } catch (e) {
        console.error('Search init failed', e);
      }
    }

    function handleToggleModal() {
      searchModal.classList.toggle('hidden');
      if (!searchModal.classList.contains('hidden')) {
        if (searchInput) {
          searchInput.value = '';
          searchInput.focus();
        }
        if (searchResults) {
          searchResults.innerHTML = '<p class="text-center py-8 text-slate-500">Mulai mengetik untuk mencari...</p>';
        }
        if (!fuseSearchInstance) getSearchData();
      }
    }

    searchBtns.forEach(btn => {
      btn.onclick = handleToggleModal;
    });

    if (closeSearch) closeSearch.onclick = handleToggleModal;

    window.onkeydown = function(e) {
      if (e.key === 'Escape' && !searchModal.classList.contains('hidden')) {
        handleToggleModal();
      }
    };

    if (searchInput) {
      searchInput.oninput = function(e) {
        if (!fuseSearchInstance || !searchResults) return;
        
        var query = e.target.value;
        if (!query) {
          searchResults.innerHTML = '<p class="text-center py-8 text-slate-500">Mulai mengetik untuk mencari...</p>';
          return;
        }

        var results = fuseSearchInstance.search(query);
        if (results.length === 0) {
          searchResults.innerHTML = '<p class="text-center py-8 text-slate-500">Tidak ada hasil ditemukan.</p>';
          return;
        }

        searchResults.innerHTML = results.map(function(res) {
          return '<a href="' + res.item.path + '" class="block p-4 rounded-2xl hover:bg-violet-500/10 border border-transparent hover:border-violet-500/50 transition-all group">' +
            '<div class="flex flex-col">' +
              '<span class="text-[10px] text-violet-500 font-bold uppercase tracking-widest">' + res.item.category + '</span>' +
              '<h4 class="font-bold text-slate-900 dark:text-white group-hover:text-violet-500">' + res.item.title + '</h4>' +
              '<p class="text-xs text-slate-500 line-clamp-1">' + res.item.description + '</p>' +
            '</div>' +
          '</a>';
        }).join('');
      };
    }

    if (searchModal) {
      searchModal.onclick = function(e) {
        if (e.target === searchModal) handleToggleModal();
      };
    }
  }

  setupSearch();
  document.addEventListener('astro:after-swap', setupSearch);
</script>

<style>
  .animate-fade-in { animation: fadeIn 0.2s ease-out; }
  .animate-slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>
