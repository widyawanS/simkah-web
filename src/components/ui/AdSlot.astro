---
import { getSiteSettings } from "@lib/keystatic";

export interface Props {
  type: 'home' | 'post' | 'tools';
  class?: string;
}

const { type, class: className } = Astro.props;
const settings = await getSiteSettings();
const ads = settings?.ads || { isActive: false };

const slotId = type === 'home' ? ads.homeAd : type === 'post' ? ads.postAd : ads.toolsAd;
---

{ads.isActive && slotId && (
  <div class={`ad-container my-8 text-center overflow-hidden ${className}`}>
    <span class="text-[10px] text-slate-400 uppercase tracking-widest block mb-2 font-mono">ADVERTISEMENT</span>
    <div class="bg-slate-50 dark:bg-slate-900/50 border border-slate-200/60 dark:border-slate-800/60 rounded-xl min-h-[280px] sm:min-h-[100px] flex items-center justify-center transition-all">
        <!-- Google AdSense Ins -->
        <ins class="adsbygoogle"
            style="display:block; min-width:250px; min-height:90px"
            data-ad-client={ads.adClient}
            data-ad-slot={slotId}
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
        <script is:inline>
            // Only push if the library is ready or wait for it
            (window.adsbygoogle = window.adsbygoogle || []).push({});
        </script>
    </div>
  </div>
)}
